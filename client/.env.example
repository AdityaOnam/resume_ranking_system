# Client Environment Variables (.env.local for local development)
# Leave REACT_APP_API_URI empty or set to localhost for local dev
# In production on Vercel, this will be set to /api automatically

# For LOCAL DEVELOPMENT:
REACT_APP_API_URI=http://localhost:5000/api

# For PRODUCTION on Vercel (optional - defaults to /api):
# REACT_APP_API_URI=/api

