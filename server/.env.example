# Server Environment Variables (.env for local development)
# Copy this to .env in the server directory

# Supabase Configuration (Required)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Environment (development, production, testing)
ENVIRONMENT=development

# Note: In production on Vercel, set these variables in Vercel Dashboard → Settings → Environment Variables

