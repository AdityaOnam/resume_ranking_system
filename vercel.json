{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/build",
  "framework": "create-react-app",
  "env": {
    "REACT_APP_API_URI": "@react_app_api_uri"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
